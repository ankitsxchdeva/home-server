# Environment files with secrets
.env
**/.env

# Home Assistant - Sensitive Data & Runtime Files
home-assistant/config/secrets.yaml
home-assistant/config/.storage/
home-assistant/config/.cloud/
home-assistant/config/home-assistant_v2.db*
home-assistant/config/home-assistant.log*
home-assistant/config/.HA_VERSION
home-assistant/config/zigbee.db*
home-assistant/config/deps/
home-assistant/config/tts/
home-assistant/config/.google.token
home-assistant/config/known_devices.yaml
home-assistant/config/ip_bans.yaml

# Home Assistant - Device & User specific files
home-assistant/config/.*
!home-assistant/config/.gitkeep

# CUPS - Sensitive printer configs and runtime data
cups/config/printers.conf*
cups/config/cupsd.conf*
cups/config/classes.conf*
cups/config/cups-browsed.conf
cups/config/snmp.conf
cups/config/ssl/
cups/config/interfaces/
cups/config/ppd/
cups/config/*.types
cups/config/*.convs

# Service data directories
uptime-kuma/data/
reddit-swap-notifier/data/

# Matter Server - Runtime data, certificates, and device info
matter-server/data/

# Pi-hole data
pihole/etc-pihole/
pihole/etc-dnsmasq.d/

# NetAlertX data
netalertx/config/
netalertx/db/

# Glances config (if customized)
# glances/glances.conf - keep this tracked for consistency

# Docker & System files
.DS_Store
Thumbs.db
*.log
*.tmp
*.backup.*

# IDE & agent tooling files
.vscode/
.cursor/
.claude/
.browser-sessions/
*.swp
*.swo

.venv/
# Python bytecode
__pycache__/
*.pyc

# Home Assistant - Backups (full config archive: contains secrets.yaml & auth tokens)
home-assistant/config/backups/

# Traefik runtime data (certs are secrets)
traefik/

# WireGuard config (private keys)
wg-easy/

# DDNS runtime logs
ddns/

# Deprecated service data (never commit)
deprecated/pihole/etc-pihole/
deprecated/pihole/etc-dnsmasq.d/

# Caddy runtime (certs are secrets)
caddy/data/
caddy/config/

# Home Assistant - stock blueprints regenerated on every start
home-assistant/config/blueprints/
