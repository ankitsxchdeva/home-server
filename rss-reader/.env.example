# How often to rebuild the digest
POLL_INTERVAL_SECONDS=1800

# Which origin may fetch data.json (the Pages site). Use * to allow anyone.
ALLOW_ORIGIN=https://ankitsachdeva.com

# "Today" for the digest window: only items published since midnight in this
# timezone are kept
DIGEST_TZ=America/Chicago

# Be a polite bot
USER_AGENT=lede/1.0 (+https://ankitsachdeva.com/lede)

# Shared secret for the saved/read-later write endpoints (the funnel URL is
# public). The frontend asks for it once and keeps it in localStorage.
# Leave empty to allow writes from anyone.
SAVE_TOKEN=

# Optional: route sources marked `paywall: true` through the existing 13ft proxy.
# Compose `include:` puts every service on one network, so use the service name:
# PAYWALL_PROXY=http://13ft:5000

# Optional: timezone for log timestamps, defaults to UTC
#TZ=America/Chicago
